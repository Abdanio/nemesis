PORT=3000
CORS_ORIGIN=*

# Turso Database Configuration
# Get these values from https://app.turso.tech:
# 1. Create or select a database
# 2. Copy CONNECTION URL and AUTH TOKEN from database settings

TURSO_CONNECTION_URL=libsql://your-db-name-hash.turso.tech
TURSO_AUTH_TOKEN=your-auth-token-here

# Optional: Google Drive for backup data downloads
GDRIVE_DB_ZIP_URL=
